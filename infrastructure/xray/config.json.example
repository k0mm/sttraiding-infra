{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 1080,
      "protocol": "socks",
      "settings": { "auth": "noauth", "udp": true },
      "tag": "socks-in"
    },
    {
      "listen": "0.0.0.0",
      "port": 8080,
      "protocol": "http",
      "tag": "http-in"
    }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [{
          "address": "YOUR_XRAY_SERVER_IP",
          "port": 443,
          "users": [{ "id": "YOUR_VLESS_UUID", "encryption": "none" }]
        }]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls"
      },
      "tag": "proxy"
    },
    { "protocol": "freedom", "tag": "direct" }
  ],
  "routing": {
    "rules": [
      {
        "type": "field",
        "domain": ["geosite:telegram"],
        "outboundTag": "proxy"
      }
    ]
  }
}
