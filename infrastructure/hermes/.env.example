DOMAIN=sttraiding.ru

# LLM Providers
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# Telegram Integration
TELEGRAM_BOT_TOKEN=          # BotFather token
TELEGRAM_ALLOWED_USERS=      # Comma-separated Telegram user IDs
